### 2. Register another user (for messaging tests)
POST {{baseUrl}}/api/auth/register
Content-Type: {{contentType}}

{
  "email": "fanyicharllson@gmail.com",
  "password": "SecurePassword456!",
  "displayName": "Bob Smith",
  "studentId": "ICT2024002"
}

### 3. Login user
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "fanyicharllson.fanyi@ictuniversity.edu.cm",
  "password": "SecurePassword123!"
}

### 4. Validate token
GET {{baseUrl}}/api/auth/validate
Authorization: Bearer {{token}}

### 5. Update user type to SELLER
PATCH {{baseUrl}}/api/auth/user-type
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "userType": "SELLER"
}

### 6. Update user type back to STUDENT
PATCH {{baseUrl}}/api/auth/user-type
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "userType": "STUDENT"
}

### 7. Resend verification code
POST {{baseUrl}}/api/auth/resend-token
Content-Type: {{contentType}}

{
  "email": "student12@ictuniversity.edu.cm"
}

### 8. Verify emailed code
POST {{baseUrl}}/api/auth/verify-code
Content-Type: {{contentType}}

{
  "email": "fanyicharllson@gmail.com",
  "code": "ICTUEx-892383"
}

