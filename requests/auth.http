### 1. Register a new user
POST {{baseUrl}}/api/auth/register
Content-Type: {{contentType}}

{
  "email": "student12@ictuniversity.edu.cm",
  "password": "SecurePassword123!",
  "displayName": "Alice Johnson",
  "studentId": "ICT2024004"
}

### 2. Register another user (for messaging tests)
POST {{baseUrl}}/api/auth/register
Content-Type: {{contentType}}

{
  "email": "student2@ictuniversity.edu.cm",
  "password": "SecurePassword456!",
  "displayName": "Bob Smith",
  "studentId": "ICT2024002"
}

### 3. Login user
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "student1@ictuniversity.edu.cm",
  "password": "SecurePassword123!"
}

### 4. Validate token
GET {{baseUrl}}/api/auth/validate
Authorization: Bearer {{token}}

### 5. Update user type to SELLER
PATCH {{baseUrl}}/api/auth/user-type
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "userType": "SELLER"
}

### 6. Update user type back to STUDENT
PATCH {{baseUrl}}/api/auth/user-type
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "userType": "STUDENT"
}
